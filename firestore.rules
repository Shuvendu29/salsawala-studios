rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isFaculty() {
      return isSignedIn() && (getUserRole() == 'faculty' || getUserRole() == 'admin');
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Anyone can read their own profile; admins can read all
      allow read: if isOwner(userId) || isAdmin();
      // User can create/update their own profile; admin can update any
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Classes ───────────────────────────────────────────────────────────────

    match /classes/{classId} {
      // Anyone (including unauthenticated) can read classes for the public schedule
      allow read: if true;
      // Only admin can create/update/delete classes
      allow write: if isAdmin();
    }

    // ── Events ────────────────────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Bookings ──────────────────────────────────────────────────────────────

    match /bookings/{bookingId} {
      // Users can read their own bookings; faculty/admin can read all
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isFaculty()
      );
      // Authenticated users can create bookings for themselves
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Users can cancel their own; admin can do anything
      allow update: if isSignedIn() && (
        isOwner(resource.data.userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Attendance ────────────────────────────────────────────────────────────

    match /attendance/{attendanceId} {
      // Users can read their own attendance; faculty/admin can read all
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || isFaculty()
      );
      // Only faculty and admin can mark attendance
      allow create, update: if isFaculty();
      allow delete: if isAdmin();
    }

    // ── Reviews ───────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      // Anyone can read approved reviews
      allow read: if resource.data.approved == true || isAdmin();
      // Authenticated users can submit reviews
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Users can edit their own unapproved reviews; admin can approve/edit all
      allow update: if isSignedIn() && (
        (isOwner(resource.data.userId) && resource.data.approved == false) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
